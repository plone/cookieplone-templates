{
  {%- if cookiecutter.frontend_path != '' %}
  "eslint.workingDirectories": ["{{ cookiecutter.__frontend_eslint_working_directories }}"],
  "stylelint.enable": true,
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "[css][less][scss]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.stylelint": "explicit"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  {%- endif %}
  {%- if cookiecutter.backend_path != '' %}
  "ruff.organizeImports": true,
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestArgs": [
    "{{ cookiecutter.__backend_tests_path }}"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  {%- endif %}
  {%- if cookiecutter.ansible_path != '' %}
  "ansible.python.interpreterPath": "${workspaceFolder}/{{ cookiecutter.__ansible_interpreter_base }}/python",
  "ansible.validation.lint.path": "{{ cookiecutter.__ansible_interpreter_base }}/ansible-lint",
  "ansible.validation.lint.arguments": "-c .ansible-lint",
  {%- endif %}
  "[markdown]": {
    "editor.formatOnSave": false
  }
}
