{
    "id": "backend_addon",
    "schema": {
        "title": "Plone Backend Add-on",
        "description": "A backend add-on for Plone 6, with optional headless support and CI/CD scaffolding.",
        "version": "2.0",
        "properties": {
            "title": {
                "type": "string",
                "title": "Addon Title",
                "description": "Human-readable name for the add-on.",
                "default": "Addon",
                "validator": ""
            },
            "description": {
                "type": "string",
                "title": "Description",
                "description": "A short description of your add-on.",
                "default": "A new addon for Plone",
                "validator": ""
            },
            "author": {
                "type": "string",
                "title": "Author",
                "description": "Name of the add-on author or organization.",
                "default": "Plone Community",
                "validator": ""
            },
            "email": {
                "type": "string",
                "title": "Author E-mail",
                "description": "Contact email for the add-on author.",
                "default": "collective@plone.org",
                "format": "email",
                "validator": ""
            },
            "github_organization": {
                "type": "string",
                "title": "GitHub Username or Organization",
                "description": "Organization or username used to build the repository URL.",
                "default": "collective",
                "validator": ""
            },
            "use_prerelease_versions": {
                "type": "string",
                "title": "Should we use prerelease versions?",
                "description": "Whether to include alpha, beta, and release candidate versions when resolving the Plone version.",
                "default": "{{ 'No' | use_prerelease_versions }}",
                "validator": "",
                "oneOf": [
                    {"const": "Yes", "title": "Yes"},
                    {"const": "No", "title": "No"}
                ]
            },
            "plone_version": {
                "type": "string",
                "title": "Plone Version",
                "description": "Plone backend version to use. Automatically resolved to the latest available release.",
                "default": "{{ cookiecutter.use_prerelease_versions | latest_plone }}",
                "validator": "cookieplone.validators.plone_version"
            },
            "python_package_name": {
                "type": "string",
                "title": "Python Package Name",
                "description": "Dotted Python package name for the backend add-on (e.g. collective.myaddon).",
                "default": "{{ cookiecutter.github_organization|lower }}.{{ cookiecutter.title|replace(' ', '')|replace('-', '_')|replace('.', '')|lower }}",
                "validator": "cookieplone.validators.python_package_name"
            },
            "feature_headless": {
                "type": "boolean",
                "title": "Support headless Plone?",
                "description": "Include REST API serializers and other files required for a headless Plone setup.",
                "default": true,
                "validator": ""
            },
            "initialize_ci": {
                "type": "boolean",
                "title": "Add CI configuration?",
                "description": "Include a GitHub Actions workflow for continuous integration.",
                "default": true,
                "validator": ""
            },
            "initialize_documentation": {
                "type": "boolean",
                "title": "Add documentation scaffold?",
                "description": "Generate a Sphinx-based documentation structure using the Plone documentation starter.",
                "default": true,
                "validator": ""
            },
            "__year": {
                "type": "string",
                "title": "__year",
                "default": "{% now 'local', '%Y' %}",
                "validator": "",
                "format": "computed"
            },
            "__project_slug": {
                "type": "string",
                "title": "__project_slug",
                "default": "{{ cookiecutter.python_package_name }}",
                "validator": "",
                "format": "computed"
            },
            "__repository_url": {
                "type": "string",
                "title": "__repository_url",
                "default": "https://github.com/{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
                "validator": "",
                "format": "computed"
            },
            "__repository_git": {
                "type": "string",
                "title": "__repository_git",
                "default": "git@github.com:{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
                "validator": "",
                "format": "computed"
            },
            "__feature_headless": {
                "type": "string",
                "title": "__feature_headless",
                "default": "{{ '1' if cookiecutter.feature_headless else '0' }}",
                "validator": "",
                "format": "computed"
            },
            "__feature_distribution": {
                "type": "string",
                "title": "__feature_distribution",
                "default": "0",
                "validator": "",
                "format": "computed"
            },
            "__package_path": {
                "type": "string",
                "title": "__package_path",
                "default": "{{ cookiecutter.python_package_name | package_path }}",
                "validator": "",
                "format": "computed"
            },
            "__folder_name": {
                "type": "string",
                "title": "__folder_name",
                "default": "{{ cookiecutter.python_package_name }}",
                "validator": "",
                "format": "computed"
            },
            "__python_package_name_upper": {
                "type": "string",
                "title": "__python_package_name_upper",
                "default": "{{ cookiecutter.python_package_name | pascal_case }}",
                "validator": "",
                "format": "computed"
            },
            "__supported_versions_python": {
                "type": "array",
                "title": "__supported_versions_python",
                "default": ["3.10", "3.11", "3.12", "3.13"],
                "validator": "",
                "format": "computed"
            },
            "__supported_versions_plone": {
                "type": "array",
                "title": "__supported_versions_plone",
                "default": ["6.0", "6.1", "6.2"],
                "validator": "",
                "format": "computed"
            },
            "__backend_managed_by_uv": {
                "type": "string",
                "title": "__backend_managed_by_uv",
                "default": "false",
                "validator": "",
                "format": "computed"
            },
            "__python_version_identifier": {
                "type": "string",
                "title": "__python_version_identifier",
                "default": "{{ cookiecutter.__supported_versions_python[0] | replace('.', '') }}",
                "validator": "",
                "format": "computed"
            },
            "__profile_language": {
                "type": "string",
                "title": "__profile_language",
                "default": "en",
                "validator": "",
                "format": "computed"
            },
            "__version_package": {
                "type": "string",
                "title": "__version_package",
                "default": "1.0.0a0",
                "validator": "",
                "format": "computed"
            },
            "__profile_version": {
                "type": "string",
                "title": "__profile_version",
                "default": "1000",
                "validator": "",
                "format": "computed"
            },
            "__backend_addon_git_initialize": {
                "type": "string",
                "title": "__backend_addon_git_initialize",
                "default": "1",
                "validator": "",
                "format": "computed"
            },
            "__backend_addon_format": {
                "type": "string",
                "title": "__backend_addon_format",
                "default": "1",
                "validator": "",
                "format": "computed"
            },
            "__cookieplone_repository_path": {
                "type": "string",
                "title": "__cookieplone_repository_path",
                "default": "",
                "validator": "",
                "format": "computed"
            },
            "__generator_sha": {
                "type": "string",
                "title": "__generator_sha",
                "default": "",
                "validator": "",
                "format": "computed"
            },
            "__generator_template_url": {
                "type": "string",
                "title": "__generator_template_url",
                "default": "https://github.com/plone/cookieplone-templates/tree/main/{{ cookiecutter.__cookieplone_template }}",
                "validator": "",
                "format": "computed"
            },
            "__generator_date_long": {
                "type": "string",
                "title": "__generator_date_long",
                "default": "{% now 'utc', '%Y-%m-%d %H:%M:%S' %}",
                "validator": "",
                "format": "computed"
            },
            "__generator_signature": {
                "type": "string",
                "title": "__generator_signature",
                "default": "This was generated by [the cookieplone-templates {{ cookiecutter.__cookieplone_template }} template]({{ cookiecutter.__generator_template_url }}) on {{ cookiecutter.__generator_date_long }}",
                "validator": "",
                "format": "computed"
            }
        }
    },
    "config": {
        "extensions": [
            "cookieplone.filters.latest_plone",
            "cookieplone.filters.use_prerelease_versions",
            "cookieplone.filters.pascal_case",
            "cookieplone.filters.package_namespace_path",
            "cookieplone.filters.package_path"
        ],
        "no_render": [
            "news/.changelog_template.jinja"
        ],
        "subtemplates": [
            {
                "id": "docs/starter",
                "title": "Generate documentation scaffold",
                "enabled": "{{ '1' if cookiecutter.initialize_documentation else '0' }}"
            },
            {
                "id": "ide/vscode",
                "title": "Setup VSCode configuration",
                "enabled": "{{ '1' if cookiecutter.initialize_ci else '0' }}"
            },
            {
                "id": "ci/gh_backend_addon",
                "title": "Setup GitHub CI",
                "enabled": "{{ '1' if cookiecutter.initialize_ci else '0' }}"
            }
        ]
    }
}
