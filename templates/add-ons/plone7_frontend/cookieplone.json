{
    "id": "plone7_frontend",
    "schema": {
        "title": "Plone Seven Add-on",
        "description": "A Plone Seven (next-generation frontend) add-on scaffold.",
        "version": "2.0",
        "properties": {
            "title": {
                "type": "string",
                "title": "Add-on Title",
                "description": "Human-readable name for the add-on.",
                "default": "Seven Add-on",
                "validator": ""
            },
            "frontend_addon_name": {
                "type": "string",
                "title": "Frontend Add-on Name",
                "description": "Short slug used as the NPM package name and output folder (e.g. seven-myaddon).",
                "default": "{{ cookiecutter.title | slugify }}",
                "validator": "cookieplone.validators.npm_package_name"
            },
            "project_slug": {
                "type": "string",
                "title": "Project Slug",
                "description": "URL-friendly identifier used as the repository name.",
                "default": "{{ cookiecutter.title | slugify }}",
                "validator": ""
            },
            "description": {
                "type": "string",
                "title": "Description",
                "description": "A short description of your add-on.",
                "default": "A new add-on for Seven",
                "validator": ""
            },
            "author": {
                "type": "string",
                "title": "Author",
                "description": "Name of the add-on author or organization.",
                "default": "Plone Community",
                "validator": ""
            },
            "email": {
                "type": "string",
                "title": "Author E-mail",
                "description": "Contact email for the add-on author.",
                "default": "collective@plone.org",
                "format": "email",
                "validator": ""
            },
            "github_organization": {
                "type": "string",
                "title": "GitHub Username or Organization",
                "description": "Organization or username used to build the repository URL.",
                "default": "collective",
                "validator": ""
            },
            "npm_package_name": {
                "type": "string",
                "title": "NPM Package Name",
                "description": "Name of the package as published on NPM.",
                "default": "{{ cookiecutter.frontend_addon_name }}",
                "validator": "cookieplone.validators.npm_package_name"
            },
            "__folder_name": {
                "type": "string",
                "title": "__folder_name",
                "default": "{{ cookiecutter.frontend_addon_name }}",
                "validator": "",
                "format": "computed"
            },
            "__npm_package_name": {
                "type": "string",
                "title": "__npm_package_name",
                "default": "{{ cookiecutter.npm_package_name }}",
                "validator": "",
                "format": "computed"
            },
            "__version_package": {
                "type": "string",
                "title": "__version_package",
                "default": "1.0.0",
                "validator": "",
                "format": "computed"
            },
            "__generator_date_long": {
                "type": "string",
                "title": "__generator_date_long",
                "default": "{% now 'utc', '%Y-%m-%d %H:%M:%S' %}",
                "validator": "",
                "format": "computed"
            },
            "__generator_signature": {
                "type": "string",
                "title": "__generator_signature",
                "default": "This was generated by [the cookieplone-templates plone7_frontend template](https://github.com/plone/cookieplone-templates/tree/main/templates/add-ons/plone7_frontend) on {{ cookiecutter.__generator_date_long }}",
                "validator": "",
                "format": "computed"
            },
            "__cookieplone_repository_path": {
                "type": "string",
                "title": "__cookieplone_repository_path",
                "default": "",
                "validator": "",
                "format": "computed"
            }
        }
    },
    "config": {
        "extensions": [
            "cookieplone.filters.latest_volto"
        ],
        "no_render": [],
        "subtemplates": [
            {
                "id": "ide/vscode",
                "title": "Setup VSCode configuration",
                "enabled": "1"
            }
        ]
    }
}
