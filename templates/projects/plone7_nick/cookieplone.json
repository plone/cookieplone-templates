{
    "id": "plone7_nick",
    "schema": {
        "title": "Plone 7 alpha using Nick as standalone backend (experimental)",
        "description": "A standalone Node.js project template powered by Nick as backend.",
        "version": "2.0",
        "properties": {
            "title": {
                "type": "string",
                "title": "Project Title",
                "description": "Human-readable project title.",
                "default": "Plone",
                "validator": ""
            },
            "project_slug": {
                "type": "string",
                "title": "Project Slug",
                "description": "URL-friendly identifier used as the output folder and database name.",
                "default": "{{ cookiecutter.title | slugify }}",
                "validator": ""
            },
            "description": {
                "type": "string",
                "title": "Description",
                "description": "A short description of your project.",
                "default": "A standalone Nick-based Plone project.",
                "validator": ""
            },
            "author": {
                "type": "string",
                "title": "Author",
                "description": "Name of the project author or organization.",
                "default": "Plone Community",
                "validator": ""
            },
            "email": {
                "type": "string",
                "title": "Author E-mail",
                "description": "Contact email for the project author.",
                "default": "collective@plone.org",
                "format": "email",
                "validator": ""
            },
            "github_organization": {
                "type": "string",
                "title": "GitHub Username or Organization",
                "description": "Organization or username used to build repository URLs.",
                "default": "collective",
                "validator": ""
            },
            "npm_package_name": {
                "type": "string",
                "title": "NPM Package Name",
                "description": "Name of the generated package.",
                "default": "{{ cookiecutter.project_slug }}",
                "validator": "cookieplone.validators.npm_package_name"
            },
            "__folder_name": {
                "type": "string",
                "title": "__folder_name",
                "default": "{{ cookiecutter.project_slug }}",
                "validator": "",
                "format": "computed"
            },
            "__cookieplone_repository_path": {
                "type": "string",
                "title": "__cookieplone_repository_path",
                "default": "",
                "validator": "",
                "format": "computed"
            },
            "__generator_sha": {
                "type": "string",
                "title": "__generator_sha",
                "default": "",
                "validator": "",
                "format": "computed"
            },
            "__generator_template_url": {
                "type": "string",
                "title": "__generator_template_url",
                "default": "https://github.com/plone/cookieplone-templates/tree/main/{{ cookiecutter.__cookieplone_template }}",
                "validator": "",
                "format": "computed"
            },
            "__generator_date_long": {
                "type": "string",
                "title": "__generator_date_long",
                "default": "{% now 'utc', '%Y-%m-%d %H:%M:%S' %}",
                "validator": "",
                "format": "computed"
            },
            "__generator_signature": {
                "type": "string",
                "title": "__generator_signature",
                "default": "This was generated by [the cookieplone-templates {{ cookiecutter.__cookieplone_template }} template]({{ cookiecutter.__generator_template_url }}) on {{ cookiecutter.__generator_date_long }}",
                "validator": "",
                "format": "computed"
            }
        }
    },
    "config": {
        "extensions": [],
        "no_render": [],
        "subtemplates": [
            {
                "id": "ide/vscode",
                "title": "Setup VSCode configuration",
                "enabled": "1"
            }
        ]
    }
}
