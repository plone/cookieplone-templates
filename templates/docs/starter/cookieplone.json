{
    "id": "docs/starter",
    "schema": {
        "title": "Documentation Starter",
        "description": "Scaffold for a Plone documentation project using Sphinx.",
        "version": "2.0",
        "properties": {
            "title": {
                "type": "string",
                "title": "Title",
                "description": "Human-readable title for the documentation project.",
                "default": "Documentation Starter",
                "validator": ""
            },
            "description": {
                "type": "string",
                "title": "Description",
                "description": "A short description of what this documentation covers.",
                "default": "A documentation starter scaffold for Plone",
                "validator": ""
            },
            "author": {
                "type": "string",
                "title": "Author",
                "description": "Author or maintainer of the documentation.",
                "default": "Plone Community",
                "validator": ""
            },
            "email": {
                "type": "string",
                "title": "Author E-mail",
                "description": "Contact e-mail for the author.",
                "default": "collective@plone.org",
                "validator": ""
            },
            "github_organization": {
                "type": "string",
                "title": "GitHub Organization",
                "description": "GitHub username or organization slug that will host the docs repository.",
                "default": "collective",
                "validator": ""
            },
            "initialize_git": {
                "type": "string",
                "title": "Initialize Git Repository",
                "description": "Whether to initialize a git repository in the generated folder.",
                "default": "1",
                "validator": "",
                "oneOf": [
                    {"const": "1", "title": "Yes"},
                    {"const": "0", "title": "No"}
                ]
            },
            "__folder_name": {
                "type": "string",
                "title": "__folder_name",
                "default": "{{ cookiecutter.github_organization|lower }}.{{ cookiecutter.title|replace(' ', '')|replace('-', '_')|replace('.', '')|lower }}",
                "validator": "",
                "format": "computed"
            },
            "__normalized_package_name": {
                "type": "string",
                "title": "__normalized_package_name",
                "default": "{{ cookiecutter.title|replace(' ', '')|replace('-', '_')|replace('.', '')|lower }}",
                "validator": "",
                "format": "computed"
            },
            "__project_slug": {
                "type": "string",
                "title": "__project_slug",
                "default": "{{ cookiecutter.__normalized_package_name }}",
                "validator": "",
                "format": "computed"
            },
            "__repository_url": {
                "type": "string",
                "title": "__repository_url",
                "default": "https://github.com/{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
                "validator": "",
                "format": "computed"
            },
            "__repository_git": {
                "type": "string",
                "title": "__repository_git",
                "default": "git@github.com:{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
                "validator": "",
                "format": "computed"
            },
            "__year": {
                "type": "string",
                "title": "__year",
                "default": "{% now 'local', '%Y' %}",
                "validator": "",
                "format": "computed"
            },
            "__generator_date_long": {
                "type": "string",
                "title": "__generator_date_long",
                "default": "{% now 'utc', '%Y-%m-%d %H:%M:%S' %}",
                "validator": "",
                "format": "computed"
            },
            "__generator_signature": {
                "type": "string",
                "title": "__generator_signature",
                "default": "This was generated by the [cookieplone-templates docs/starter template](https://github.com/plone/cookieplone-templates/tree/main/templates/docs/starter) on {{ cookiecutter.__generator_date_long }}",
                "validator": "",
                "format": "computed"
            },
            "__documentation_starter_format": {
                "type": "string",
                "title": "__documentation_starter_format",
                "default": "1",
                "validator": "",
                "format": "computed"
            },
            "__cookieplone_repository_path": {
                "type": "string",
                "title": "__cookieplone_repository_path",
                "default": "",
                "validator": "",
                "format": "computed"
            }
        }
    },
    "config": {
        "extensions": [
            "cookieplone.filters.latest_plone",
            "cookieplone.filters.use_prerelease_versions",
            "cookieplone.filters.pascal_case",
            "cookieplone.filters.package_namespaces",
            "cookieplone.filters.package_path"
        ],
        "no_render": [
            "docs/_templates/404.html"
        ]
    }
}
